local function updatePlayerList()
    playerListFrame:ClearAllChildren()
    local layout = Instance.new("UIListLayout", playerListFrame)
    local count = 0
    for _, p in pairs(game.Players:GetPlayers()) do
        if p ~= player then
            count = count + 1
            local btn = Instance.new("TextButton", playerListFrame)
            btn.Size = UDim2.new(1, 0, 0, 30)
            btn.Text = p.Name
            btn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
            btn.TextColor3 = Color3.new(1, 1, 1)
            btn.MouseButton1Click:Connect(function()
                targetPlayer = p
                selectedLabel.Text = "Destino: " .. p.Name
                playerListFrame.Visible = false
            end)
        end
    end
    playerListFrame.CanvasSize = UDim2.new(0, 0, 0, count * 30)
end

selectedLabel.MouseButton1Click:Connect(function()
    playerListFrame.Visible = not playerListFrame.Visible
    if playerListFrame.Visible then updatePlayerList() end
end)

