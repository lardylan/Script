-- FUNCIÓN SWITCH MEJORADA (MÁS PEQUEÑA Y RESPONSIVA)
local function createSwitch(name, posY, callback)
    local bg = Instance.new("TextButton", MenuPrincipal) -- Usamos TextButton para que sea clickeable en todo el cuadro
    bg.Text = ""
    bg.Size = UDim2.new(0, 40, 0, 20)
    bg.Position = UDim2.new(0.7, -10, 0, posY)
    bg.BackgroundColor3 = Color3.fromRGB(180, 0, 0)
    Instance.new("UICorner", bg).CornerRadius = UDim.new(1, 0)
    
    local dot = Instance.new("Frame", bg)
    dot.Size = UDim2.new(0, 16, 0, 16)
    dot.Position = UDim2.new(0, 2, 0.5, -8)
    dot.BackgroundColor3 = Color3.new(1, 1, 1)
    Instance.new("UICorner", dot).CornerRadius = UDim.new(1, 0)

    local txt = Instance.new("TextLabel", MenuPrincipal)
    txt.Text = name
    txt.Size = UDim2.new(0, 100, 0, 20)
    txt.Position = UDim2.new(0.1, 0, 0, posY)
    txt.TextColor3 = Color3.new(1, 1, 1)
    txt.BackgroundTransparency = 1
    txt.TextXAlignment = Enum.TextXAlignment.Left

    local on = false
    bg.MouseButton1Click:Connect(function()
        on = not on
        bg.BackgroundColor3 = on and Color3.fromRGB(0, 180, 0) or Color3.fromRGB(180, 0, 0)
        dot:TweenPosition(on and UDim2.new(1, -18, 0.5, -8) or UDim2.new(0, 2, 0.5, -8), "Out", "Quad", 0.15, true)
        callback(on)
    end)
end

-- OPCIONES
createSwitch("HITBOX", 60, function(v)
    _G.BigHit = v
    task.spawn(function()
        while _G.BigHit do
            for _, p in pairs(game.Players:GetPlayers()) do
                if p ~= game.Players.LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                    p.Character.HumanoidRootPart.Size = Vector3.new(20, 20, 20)
                    p.Character.HumanoidRootPart.Transparency = 0.7
                end
            end
            task.wait(0.5)
        end
    end)
end)

