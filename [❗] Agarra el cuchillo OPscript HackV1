-- FUNCIÓN SWITCH ( ● )
local function createSwitch(name, posY, callback)
    local txt = Instance.new("TextLabel", MenuPrincipal)
    txt.Text = name
    txt.Size = UDim2.new(0, 80, 0, 30)
    txt.Position = UDim2.new(0.1, 0, 0, posY)
    txt.TextColor3 = Color3.new(1,1,1)
    txt.BackgroundTransparency = 1

    local bg = Instance.new("Frame", MenuPrincipal)
    bg.Size = UDim2.new(0, 45, 0, 22)
    bg.Position = UDim2.new(0.6, 0, 0, posY + 4)
    bg.BackgroundColor3 = Color3.fromRGB(200, 0, 0)
    Instance.new("UICorner", bg).CornerRadius = UDim.new(1, 0)

    local btn = Instance.new("TextButton", bg)
    btn.Text = "●"
    btn.Size = UDim2.new(0, 22, 0, 22)
    btn.Position = UDim2.new(0, 0, 0, 0)
    btn.BackgroundTransparency = 1
    btn.TextColor3 = Color3.new(1,1,1)

    local on = false
    btn.MouseButton1Click:Connect(function()
        on = not on
        bg.BackgroundColor3 = on and Color3.fromRGB(0, 200, 0) or Color3.fromRGB(200, 0, 0)
        btn:TweenPosition(on and UDim2.new(0.5, 0, 0, 0) or UDim2.new(0, 0, 0, 0), "Out", "Quad", 0.2)
        callback(on)
    end)
end

