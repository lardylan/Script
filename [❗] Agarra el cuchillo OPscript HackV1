-- FUNCIÓN SWITCH (●) ESTILO SLIDE
local function createSwitch(name, posY, callback)
    local bg = Instance.new("Frame", MenuPrincipal)
    bg.Size = UDim2.new(0, 50, 0, 25)
    bg.Position = UDim2.new(0.7, 0, 0, posY)
    bg.BackgroundColor3 = Color3.fromRGB(200, 0, 0)
    Instance.new("UICorner", bg).CornerRadius = UDim.new(1, 0)
    
    local dot = Instance.new("TextButton", bg)
    dot.Text = "●"
    dot.Size = UDim2.new(0, 25, 0, 25)
    dot.Position = UDim2.new(0, 0, 0, 0)
    dot.BackgroundTransparency = 1
    dot.TextColor3 = Color3.new(1, 1, 1)

    local txt = Instance.new("TextLabel", MenuPrincipal)
    txt.Text = name
    txt.Position = UDim2.new(0.1, 0, 0, posY)
    txt.TextColor3 = Color3.new(1, 1, 1)
    txt.BackgroundTransparency = 1

    local on = false
    dot.MouseButton1Click:Connect(function()
        on = not on
        bg.BackgroundColor3 = on and Color3.fromRGB(0, 200, 0) or Color3.fromRGB(200, 0, 0)
        dot:TweenPosition(on and UDim2.new(0.5, 0, 0, 0) or UDim2.new(0, 0, 0, 0), "Out", "Quad", 0.2)
        callback(on)
    end)
end

