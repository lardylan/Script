local function checkForTargetRarities()
    for _, brainrot in ipairs(brainrotsFolder:GetDescendants()) do
        local charRarity = brainrot:FindFirstChild("CharRarity", true)
        if charRarity and charRarity:IsA("TextLabel") 
           and targetRarities[charRarity.Text] 
           and not isProcessing then
            
            teleportToBrainrot(brainrot)
            return
        end
    end
end

-- ====================== COLLECT CASH FUNCTION ======================

local function getRootPart()
    local char = player.Character or player.CharacterAdded:Wait()
    return char:WaitForChild("HumanoidRootPart")
end

local function autoCollectMyBase(myBase)
    local root = getRootPart()
    local floor1 = myBase:FindFirstChild("Floor1")
    if not floor1 then return warn("No Floor1") end
    
    local platforms = floor1:FindFirstChild("Platforms")
    if not platforms then return warn("No Platforms folder") end

    print("🔥 Auto-collecting cash on your base:", myBase.Name)

    for _, platform in ipairs(platforms:GetChildren()) do
        if platform:IsA("Model") or platform:IsA("Folder") then
            local collectFolder = platform:FindFirstChild("Collect")
            if collectFolder then
                
                local mainCollect = collectFolder:GetChildren()[2]
                if mainCollect and (mainCollect:IsA("BasePart") or mainCollect:IsA("Model")) then
                    firetouchinterest(root, mainCollect, 0)
                    task.wait(0.03)
                end

                local touchInterest = collectFolder:FindFirstChild("TouchInterest")
                if touchInterest then
                    firetouchinterest(root, touchInterest.Parent, 0)
                    task.wait(0.03)
                end
            end
        end
    end

    print("✅ Cash collection cycle finished for base", myBase.Name)
end

local function startAutoCollectCash()
    task.spawn(function()
        while autoCollectCashEnabled do
            local collected = false
            
            for _, base in pairs(basesFolder:GetChildren()) do
                local baseDisplay = base:FindFirstChild("BaseDisplay", true)
                if baseDisplay then
                    local textLabel = baseDisplay:FindFirstChild("TextLabel", true)
                    if textLabel and textLabel:IsA("TextLabel") then
                        if string.find(textLabel.Text, "Your Base") or textLabel.Text == "Your Base" then
                            autoCollectMyBase(base)
                            collected = true
                            break
                        end
                    end
                end
            end
            
            if not collected then
                warn("Could not find your base for cash collection")
            end
            
            task.wait(1)  -- Loop every 1 second
        end
    end)
end

