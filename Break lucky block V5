                for _, b in pairs(workspace:GetDescendants()) do if b.Name:lower():find("lucky") and b:IsA("BasePart") then char.HumanoidRootPart.CFrame = b.CFrame * CFrame.new(0,4,0); p:Activate(); fireclickdetector(b:FindFirstChild("ClickDetector")); task.wait(0.05); break end end end
            end
        end
    end)
