    local noclip = false; CrearSwitch("NO-CLIP", function(val) noclip = val; game:GetService("RunService").Stepped:Connect(function() if noclip then for _,v in pairs(LP.Character:GetDescendants()) do if v:IsA("BasePart") then v.CanCollide = false end end end end) end)
    CrearSwitch("FULL BRIGHT", function(val) local L = game:GetService("Lighting"); L.Brightness = val and 2 or 1; L.GlobalShadows = not val end)
    CrearSwitch("REJOIN", function(val) if val then game:GetService("TeleportService"):Teleport(game.PlaceId, LP) end end)
