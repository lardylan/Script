    -- BUCLE LÓGICO FARM
    task.spawn(function()
        while task.wait(0.1) do
            local char = LP.Character
            if not char or not char:FindFirstChild("HumanoidRootPart") then continue end
            if autoCash then for _, v in pairs(workspace:GetChildren()) do if v.Name:find("Cash") or v.Name:find("Brainrot") then char.HumanoidRootPart.CFrame = (v:IsA("BasePart") and v or v.PrimaryPart).CFrame; task.wait(0.05) end end end
