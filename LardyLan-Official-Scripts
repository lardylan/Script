local function startLoading()
    KeyFrame.Visible = false
    local LoadUI = Instance.new("Frame", ScreenGui)
    LoadUI.Size = UDim2.new(1, 0, 1, 0); LoadUI.BackgroundColor3 = Color3.new(0, 0, 0)
    
    local Status = Instance.new("TextLabel", LoadUI)
    Status.Size = UDim2.new(1, 0, 0, 50); Status.Position = UDim2.new(0, 0, 0.35, 0); Status.TextColor3 = Color3.new(1, 1, 1); Status.BackgroundTransparency = 1; Status.Font = "GothamBold"; Status.TextSize = 20

    local Pct = Instance.new("TextLabel", LoadUI)
    Pct.Size = UDim2.new(1, 0, 0, 50); Pct.Position = UDim2.new(0, 0, 0.42, 0); Pct.TextColor3 = Color3.fromRGB(0, 255, 0); Pct.BackgroundTransparency = 1; Pct.TextSize = 35

    local BarBack = Instance.new("Frame", LoadUI)
    BarBack.Size = UDim2.new(0.6, 0, 0, 12); BarBack.Position = UDim2.new(0.2, 0, 0.55, 0); BarBack.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    
    local BarFill = Instance.new("Frame", BarBack)
    BarFill.Size = UDim2.new(0, 0, 1, 0); BarFill.BackgroundColor3 = Color3.new(1, 1, 1) -- BARRA BLANCA

    local Copyright = Instance.new("TextLabel", LoadUI)
    Copyright.Text = "COPYRIGHT: LARDYLAN"; Copyright.Size = UDim2.new(1, 0, 0, 30); Copyright.Position = UDim2.new(0, 0, 0.65, 0); Copyright.TextColor3 = Color3.fromRGB(120, 120, 120); Copyright.BackgroundTransparency = 1

    task.spawn(function()
        while LoadUI.Parent do
            Status.Text = "ESPERA ASTA QUE LA BARRITE SE LLENE"; task.wait(2.5)
            Status.Text = "SUSCRIBE, AND LIKE THE CHANNEL : LARDYLAN"; task.wait(2.5)
        end
    end)

    local target = IS_SEA_2 and 100 or 99.9
    for i = 0, target, 0.5 do
        Pct.Text = string.format("%.1f%%", i)
        BarFill.Size = UDim2.new(i/100, 0, 1, 0)
        task.wait(0.06)
    end

    if IS_SEA_2 then
        task.wait(0.5); LoadUI:Destroy(); showSpawner()
    end
end

-- [[ 3. PANEL SPAWNER ]]
function showSpawner()
    local Main = Instance.new("Frame", ScreenGui)
    Main.Size = UDim2.new(0, 400, 0, 260); Main.Position = UDim2.new(0.5, -200, 0.5, -130); Main.BackgroundColor3 = Color3.fromRGB(12, 12, 12); style(Main, 12)

    local Title = Instance.new("TextLabel", Main)
    Title.Text = "SPAWNER FRUITS"; Title.Size = UDim2.new(1, 0, 0, 50); Title.TextColor3 = Color3.fromRGB(0, 255, 150); Title.BackgroundTransparency = 1; Title.TextSize = 24

    local Input = Instance.new("TextBox", Main)
    Input.PlaceholderText = "Escribe: Buddha"; Input.Size = UDim2.new(0.8, 0, 0, 45); Input.Position = UDim2.new(0.1, 0, 0.35, 0); style(Input)

    local SpawnB = Instance.new("TextButton", Main)
    SpawnB.Text = "Spawn"; SpawnB.Size = UDim2.new(0.5, 0, 0, 45); SpawnB.Position = UDim2.new(0.1, 0, 0.6, 0); SpawnB.BackgroundColor3 = Color3.fromRGB(0, 100, 255); style(SpawnB)

    local TimerL = Instance.new("TextLabel", Main)
    TimerL.Size = UDim2.new(0, 120, 0, 45); TimerL.Position = UDim2.new(0.65, 0, 0.6, 0); TimerL.Text = "READY"; TimerL.TextColor3 = Color3.fromRGB(0, 255, 0); TimerL.BackgroundTransparency = 1

    local onCD = false
    SpawnB.MouseButton1Click:Connect(function()
        -- Sensor de proximidad
        local near = false
        for _, p in pairs(game.Players:GetPlayers()) do
            if p ~= Player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                if (Player.Character.HumanoidRootPart.Position - p.Character.HumanoidRootPart.Position).Magnitude < 15 then near = true end
            end
        end

        if near then notify("ERROR", "HAY UN JUGADOR CERCA", Color3.new(1,0,0)); return end
        if onCD then notify("ESPERA", "Cooldown de 2 horas activo.", Color3.new(1,0.5,0)); return end

        if Input.Text:lower() == "buddha" then
            onCD = true; SpawnB.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
            notify("EXITO", "Fruta Buddha (East) generada.", Color3.new(0,1,0))
            local t = SPAWN_COOLDOWN
            while t > 0 do
                TimerL.Text = string.format("%02d:%02d:%02d", math.floor(t/3600), math.floor((t%3600)/60), t%60)
                task.wait(1); t = t - 1
            end
            onCD = false; TimerL.Text = "READY"; SpawnB.BackgroundColor3 = Color3.fromRGB(0, 100, 255)
        end
    end)
end

