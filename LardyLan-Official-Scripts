-- Función para Notificaciones Modernas
local function notify(title, text, color)
    local nFrame = Instance.new("Frame", ScreenGui)
    nFrame.Size = UDim2.new(0, 260, 0, 70)
    nFrame.Position = UDim2.new(1, 10, 0.85, 0)
    nFrame.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    local c = Instance.new("UICorner", nFrame)
    local s = Instance.new("UIStroke", nFrame)
    s.Color = color or Color3.new(1,1,1)
    
    local t1 = Instance.new("TextLabel", nFrame)
    t1.Text = title; t1.Size = UDim2.new(1,0,0.4,0); t1.TextColor3 = color; t1.BackgroundTransparency = 1; t1.Font = "GothamBold"
    local t2 = Instance.new("TextLabel", nFrame)
    t2.Text = text; t2.Size = UDim2.new(1,0,0.6,0); t2.Position = UDim2.new(0,0,0.4,0); t2.TextColor3 = Color3.new(1,1,1); t2.BackgroundTransparency = 1
    
    nFrame:TweenPosition(UDim2.new(1, -270, 0.85, 0), "Out", "Quart", 0.5)
    task.delay(4, function()
        nFrame:TweenPosition(UDim2.new(1, 10, 0.85, 0), "In", "Quart", 0.5)
        task.wait(0.5); nFrame:Destroy()
    end)
end

