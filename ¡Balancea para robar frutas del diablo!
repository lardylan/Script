-- FUNCIÓN CREAR SWITCH
local function createSwitch(name, posY, parent, isLocked, callback)
	local container = Instance.new("Frame")
	container.Size = UDim2.new(0.9, 0, 0, 35)
	container.Position = UDim2.new(0.05, 0, 0, posY)
	container.BackgroundTransparency = 1
	container.Parent = parent

	local label = Instance.new("TextLabel")
	label.Text = (isLocked and "🔒 " or "") .. name
	label.Size = UDim2.new(0.6, 0, 1, 0)
	label.TextColor3 = isLocked and Color3.new(0.5, 0.5, 0.5) or Color3.new(1, 1, 1)
	label.BackgroundTransparency = 1
	label.TextXAlignment = Enum.TextXAlignment.Left
	label.Parent = container

	local bg = Instance.new("Frame")
	bg.Size = UDim2.new(0, 40, 0, 20)
	bg.Position = UDim2.new(0.75, 0, 0.2, 0)
	bg.BackgroundColor3 = Color3.new(1, 0, 0)
	bg.Parent = container

	local dot = Instance.new("TextButton")
	dot.Text = "⚪"
	dot.Size = UDim2.new(0, 20, 0, 20)
	dot.BackgroundColor3 = Color3.fromRGB(150, 0, 255)
	dot.Parent = bg

	local active = false
	dot.MouseButton1Click:Connect(function()
		if isLocked and not hasOwnerAccess then 
			label.Text = "LOCK ⛓️ X"
			wait(1)
			label.Text = "🔒 " .. name
			return 
		end
		active = not active
		dot:TweenPosition(active and UDim2.new(0.5, 0, 0, 0) or UDim2.new(0, 0, 0, 0), "Out", "Quad", 0.1)
		bg.BackgroundColor3 = active and Color3.new(0, 1, 0) or Color3.new(1, 0, 0)
		callback(active)
	end)
	
	return label, dot
end

