-- 3. FUNCIÓN SWITCH PERSONALIZADA
local function crearSwitch(nombre, posicionY, callback)
    local label = Instance.new("TextLabel")
    label.Text = nombre
    label.Size = UDim2.new(0.6, 0, 0, 30)
    label.Position = UDim2.new(0.05, 0, posicionY, 0)
    label.BackgroundTransparency = 1
    label.TextColor3 = Color3.new(1, 1, 1)
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = functionsFrame

    local bgSwitch = Instance.new("Frame")
    bgSwitch.Size = UDim2.new(0, 50, 0, 25)
    bgSwitch.Position = UDim2.new(0.7, 0, posicionY, 2)
    bgSwitch.BackgroundColor3 = Color3.new(1, 0, 0) -- Rojo apagado
    bgSwitch.Parent = functionsFrame

    local circulo = Instance.new("TextButton")
    circulo.Text = "⚪"
    circulo.Size = UDim2.new(0, 25, 0, 25)
    circulo.Position = UDim2.new(0, 0, 0, 0)
    circulo.BackgroundColor3 = Color3.fromRGB(150, 0, 255) -- Color Galaxy/Púrpura
    circulo.Parent = bgSwitch

    local activado = false
    circulo.MouseButton1Click:Connect(function()
        activado = not activado
        if activado then
            circulo:TweenPosition(UDim2.new(0.5, 0, 0, 0), "Out", "Quad", 0.2)
            bgSwitch.BackgroundColor3 = Color3.new(0, 1, 0) -- Verde encendido
        else
            circulo:TweenPosition(UDim2.new(0, 0, 0, 0), "Out", "Quad", 0.2)
            bgSwitch.BackgroundColor3 = Color3.new(1, 0, 0) -- Rojo apagado
        end
        callback(activado)
    end)
end

-- 4. LÓGICA DE LAS FUNCIONES
-- NOCLIP
local noclipConnection
crearSwitch("NOCLIPIT", 0, function(estado)
    local char = game.Players.LocalPlayer.Character
    if estado then
        noclipConnection = game:GetService("RunService").Stepped:Connect(function()
            for _, part in pairs(char:GetDescendants()) do
                if part:IsA("BasePart") then part.CanCollide = false end
            end
        end)
    else
        if noclipConnection then noclipConnection:Disconnect() end
        for _, part in pairs(char:GetDescendants()) do
            if part:IsA("BasePart") then part.CanCollide = true end
        end
    end
end)

-- ZONA VIP (Bypass)
crearSwitch("ENTRAR ZONA VIP", 0.2, function(estado)
    -- Esta función desactiva las barreras que tengan el nombre "VIP" o "Barrier"
    for _, obj in pairs(game.Workspace:GetDescendants()) do
        if obj.Name:find("VIP") or obj.Name:find("Barrier") then
            if obj:IsA("BasePart") then
                obj.CanCollide = not estado
                obj.Transparency = estado and 0.8 or 0
            end
        end
    end
end)

