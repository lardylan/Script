local function tpToBase()
    local char = Player.Character
    if char and char:FindFirstChild("HumanoidRootPart") then
        playSound(SOUND_TP) -- 🔊 Sonido de TP
        char.HumanoidRootPart.CFrame = CFrame.new(POSICION_BASE)
    end
end

CheckBtn.MouseButton1Click:Connect(function()
    if TextBox.Text == KEY_CORRECTA then
        playSound(SOUND_SUCCESS) -- 🔊 Sonido de Key Correcta
        FrameKey.Visible = false
        BaseBtn.Visible = true
        FloatingBall.Visible = true
        HubText.Visible = true
        startBeating()
    else
        TextBox.Text = ""
        TextBox.PlaceholderText = "KEY INCORRECTA ❌"
    end
end)

