-- CONFIGURACIÓN FINAL LARDYLAN HUB
local KEY_CORRECTA = "LUCKY BLOCK"
-- Estas coordenadas son una aproximación a la cinta blanca de la imagen
local POS_CINTA_BLANCA = Vector3.new(-245, 4, 150) 

local Player = game.Players.LocalPlayer
local PlayerGui = Player:WaitForChild("PlayerGui")
local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")

-- Función para sonidos
local function playSound(soundId)
    local sound = Instance.new("Sound", game.Workspace)
    sound.SoundId = soundId
    sound.Volume = 1
    sound:Play()
    game.Debris:AddItem(sound, 2)
end

-- INTERFAZ PRINCIPAL
local ScreenGui = Instance.new("ScreenGui", PlayerGui)
ScreenGui.Name = "LardylanHub"
ScreenGui.ResetOnSpawn = false

-- Texto LARDYLAN HUB (Arriba del botón)
local HubText = Instance.new("TextLabel", ScreenGui)
HubText.Size = UDim2.new(0, 150, 0, 30)
HubText.Position = UDim2.new(0.05, 0, 0.15, -35)
HubText.Text = "LARDYLAN HUB"
HubText.TextColor3 = Color3.new(1, 1, 1)
HubText.BackgroundTransparency = 1
HubText.Font = Enum.Font.GothamBold
HubText.TextSize = 16
HubText.Visible = false

local function startBeating()
    local info = TweenInfo.new(0.7, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut, -1, true)
    TweenService:Create(HubText, info, {TextSize = 20, TextColor3 = Color3.new(1, 1, 0)}):Play()
end

-- Botón IR ALA BASE (Más estilizado)
local BaseBtn = Instance.new("TextButton", ScreenGui)
BaseBtn.Size = UDim2.new(0, 120, 0, 40)
BaseBtn.Position = UDim2.new(0.05, 0, 0.15, 0)
BaseBtn.Text = "IR ALA BASE"
BaseBtn.BackgroundColor3 = Color3.fromRGB(0, 170, 127)
BaseBtn.TextColor3 = Color3.new(1, 1, 1)
BaseBtn.Font = Enum.Font.GothamBold
BaseBtn.Visible = false
local Corner = Instance.new("UICorner", BaseBtn)
Corner.CornerRadius = UDim.new(0, 8)

-- Bola Flotante Móvil
local FloatingBall = Instance.new("ImageButton", ScreenGui)
FloatingBall.Size = UDim2.new(0, 50, 0, 50)
FloatingBall.Position = UDim2.new(0.1, 0, 0.5, 0)
FloatingBall.BackgroundColor3 = Color3.fromRGB(255, 170, 0)
FloatingBall.Visible = false
Instance.new("UICorner", FloatingBall).CornerRadius = UDim.new(1, 0)

-- LÓGICA DE TELETRANSPORTE A LA CINTA
local function teleport()
    local char = Player.Character
    if char and char:FindFirstChild("HumanoidRootPart") then
        playSound("rbxassetid://1548304764")
        -- Intentamos buscar la base por el nombre del jugador para ser exactos
        local base = game.Workspace:FindFirstChild(Player.Name.."'s Base") or game.Workspace:FindFirstChild("Bases"):FindFirstChild(Player.Name)
        if base then
            char.HumanoidRootPart.CFrame = base:GetModelCFrame() -- Te lleva al centro de tu base
        else
            char.HumanoidRootPart.CFrame = CFrame.new(POS_CINTA_BLANCA) -- Coordenada manual
        end
    end
end

-- EL SISTEMA DE KEY (Simplificado para el ejemplo)
-- [Aquí iría el FrameKey que ya tienes, al poner la key correcta ejecuta:]
-- BaseBtn.Visible = true; HubText.Visible = true; FloatingBall.Visible = true; startBeating()

BaseBtn.MouseButton1Click:Connect(teleport)
FloatingBall.MouseButton1Click:Connect(function() 
    BaseBtn.Visible = not BaseBtn.Visible
    HubText.Visible = BaseBtn.Visible
end)

-- Movimiento de la bola (Drag)
local dragging, dragStart, startPos
FloatingBall.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true; dragStart = input.Position; startPos = FloatingBall.Position
    end
end)
UserInputService.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        FloatingBall.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)
UserInputService.InputEnded:Connect(function(input) dragging = false end)

-- Auto TP Brainrot
Player.CharacterChildAdded:Connect(function(child)
    if child.Name == "BRAINROT" then playSound("rbxassetid://4590662766"); teleport() end
end)
