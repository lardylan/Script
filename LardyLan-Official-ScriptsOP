    task.spawn(function()
        while LoadUI.Parent do
            Status.Text = "ESPERA ASTA QUE LA BARRITE SE LLENE"; task.wait(2.5)
            Status.Text = "SUSCRIBE, AND LIKE THE CHANNEL : LARDYLAN"; task.wait(2.5)
        end
