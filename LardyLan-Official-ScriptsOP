-- [[ DETECCIÓN POR DISTANCIA DE MAPA ]]
local function checkMapDistance()
    local char = game.Players.LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if hrp then
        -- Las coordenadas del Sea 2 en Blox Fruits están en un rango específico
        -- Si la posición absoluta es mayor a 1000, detecta que no es el Sea 1
        local mag = hrp.Position.Magnitude
        if mag > 1500 and mag < 50000 then -- Rango estimado para Sea 2
            return true
        end
    end
    return false
end

