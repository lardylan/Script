local HORA_EXPIRACION = 03
local MINUTO_EXPIRACION = 00
local DURACION_SESION = 18000
local startTime = os.time()

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local Camera = workspace.CurrentCamera
local LocalPlayer = Players.LocalPlayer

local function checkExpiration()
    local t = os.date("*t")
    if t.year >= 2026 and t.month >= 4 and t.day >= 21 then
        if t.hour >= HORA_EXPIRACION and t.day == 22 then return true end
        if t.hour >= HORA_EXPIRACION and t.day == 21 and HORA_EXPIRACION > 12 then return true end
    end
    return false
end

if checkExpiration() then
    LocalPlayer:Kick("ESTE SCRIPT YA EXPIRO")
    return
end

local function modMap()
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") and not obj:IsDescendantOf(LocalPlayer.Character) and not obj.Parent:FindFirstChild("Humanoid") then
            if obj.Name:lower():find("floor") or obj.Name:lower():find("piso") or (obj.Size.X > 20 and obj.Size.Z > 20) then
                obj.Transparency = 1
                obj.CanCollide = true 
            else
                obj.Transparency = 0.6
                obj.CanCollide = false
            end
        end
    end
end
modMap()

local function showIntro()
    local screenGui = Instance.new("ScreenGui", LocalPlayer:WaitForChild("PlayerGui"))
    local label = Instance.new("TextLabel", screenGui)
    label.Size = UDim2.new(1, 0, 0.1, 0)
    label.Position = UDim2.new(0, 0, 0.1, 0)
    label.BackgroundTransparency = 1
    label.Text = "LARDYLAN HUB - VIDEO VERSION"
    label.TextSize = 40
    label.Font = Enum.Font.LuckiestGuy
    local conn = RunService.RenderStepped:Connect(function()
        label.TextColor3 = Color3.fromHSV(tick() % 5 / 5, 1, 1)
    end)
    task.delay(5, function() conn:Disconnect(); screenGui:Destroy() end)
end
showIntro()

local FOVCircle = Drawing.new("Circle")
FOVCircle.Thickness = 2
FOVCircle.Color = Color3.fromRGB(0, 255, 255)
FOVCircle.Radius = 180
FOVCircle.Visible = true

local function applyHacks(plr)
    local function modChar()
        if plr ~= LocalPlayer and plr.Character then
            local h = Instance.new("Highlight", plr.Character)
            h.FillColor = Color3.fromRGB(0, 0, 255)
            h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
            local head = plr.Character:WaitForChild("Head")
            head.Size = Vector3.new(6, 6, 6)
            head.Transparency = 0.6
            head.CanCollide = false
        end
    end
    plr.CharacterAdded:Connect(modChar)
    modChar()
end
for _, p in pairs(Players:GetPlayers()) do applyHacks(p) end
Players.PlayerAdded:Connect(applyHacks)

local function getTarget()
    local target = nil
    local dist = FOVCircle.Radius
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= LocalPlayer and v.Character and v.Character:FindFirstChild("Head") then
            local pos, onScreen = Camera:WorldToViewportPoint(v.Character.Head.Position)
            if onScreen then
                local mDist = (Vector2.new(pos.X, pos.Y) - FOVCircle.Position).Magnitude
                if mDist < dist then
                    target = v.Character.Head
                    dist = mDist
                end
            end
        end
    end
    return target
end

RunService.RenderStepped:Connect(function()
    FOVCircle.Position = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    local t = getTarget()
    if t then Camera.CFrame = CFrame.new(Camera.CFrame.Position, t.Position) end
    if os.time() - startTime >= DURACION_SESION then LocalPlayer:Kick("SESION FINALIZADA") end
end)
