        Camera.CFrame = CFrame.new(Camera.CFrame.Position, targetHead.Position)
    end
    
    if os.time() - startTime >= DURACION_SESION or checkExpiration() then
        LocalPlayer:Kick("SESION FINALIZADA / SCRIPT EXPIRO")
    end
end)
