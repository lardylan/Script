local HORA_EXPIRACION = 03
local MINUTO_EXPIRACION = 00
local DURACION_SESION = 18000
local startTime = os.time()

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local Camera = workspace.CurrentCamera
local LocalPlayer = Players.LocalPlayer

-- 1. FOV CIRCULAR (Líneas sin relleno en el medio)
local FOV = Drawing.new("Circle")
FOV.Thickness = 2
FOV.Color = Color3.fromRGB(0, 255, 255)
FOV.Radius = 180
FOV.Filled = false
FOV.Visible = true
FOV.Position = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)

-- 2. MODIFICACIÓN VISUAL DEL MAPA (Paredes atravesables)
local function applyMapMod()
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") and not obj:IsDescendantOf(LocalPlayer.Character) then
            local isFloor = obj.Name:lower():find("floor") or obj.Name:lower():find("piso") or (obj.Size.X > 15 and obj.Size.Z > 15 and obj.Size.Y < 2)
            if isFloor then
                obj.Transparency = 0.8 -- Un poco visible para no perderte
                obj.CanCollide = true 
            elseif obj.Parent:IsA("Model") and not obj.Parent:FindFirstChild("Humanoid") then
                obj.Transparency = 0.7 -- Paredes transparentes
                obj.CanCollide = false -- Atravesar
            end
        end
    end
end
applyMapMod()

-- 3. ESP, ANTENAS AZULES Y HITBOXES
local function applyHacks(plr)
    local function mod()
        if plr ~= LocalPlayer and plr.Character then
            -- ESP Cuerpo Azul
            local h = plr.Character:FindFirstChild("LardylanESP") or Instance.new("Highlight", plr.Character)
            h.Name = "LardylanESP"
            h.FillColor = Color3.fromRGB(0, 0, 255)
            h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
            
            -- HITBOX GIGANTE
            local head = plr.Character:WaitForChild("Head")
            head.Size = Vector3.new(6, 6, 6)
            head.Transparency = 0.7
            head.CanCollide = false
            
            -- ANTENA (Palo azul gigante)
            if not plr.Character:FindFirstChild("AntenaAzul") then
                local ant = Instance.new("Part", plr.Character)
                ant.Name = "AntenaAzul"
                ant.Size = Vector3.new(0.5, 40, 0.5)
                ant.Color = Color3.fromRGB(0, 0, 255)
                ant.Material = Enum.Material.Neon
                ant.CanCollide = false
                local weld = Instance.new("Weld", ant)
                weld.Part0 = head
                weld.Part1 = ant
                weld.C0 = CFrame.new(0, 20, 0)
            end
        end
    end
    plr.CharacterAdded:Connect(function() task.wait(1); mod() end)
    mod()
end

for _, p in pairs(Players:GetPlayers()) do applyHacks(p) end
Players.PlayerAdded:Connect(applyHacks)

-- 4. BUCLE PRINCIPAL (Aimbot y Centrar FOV)
RunService.RenderStepped:Connect(function()
    -- Centrar FOV siempre
    FOV.Position = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    
    -- Aimbot Logic
    local target = nil
    local dist = FOV.Radius
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= LocalPlayer and v.Character and v.Character:FindFirstChild("Head") then
            local pos, onScreen = Camera:WorldToViewportPoint(v.Character.Head.Position)
            if onScreen then
                local mDist = (Vector2.new(pos.X, pos.Y) - FOV.Position).Magnitude
                if mDist < dist then
                    target = v.Character.Head
                    dist = mDist
                end
            end
        end
    end
    
    if target then 
        Camera.CFrame = CFrame.new(Camera.CFrame.Position, target.Position) 
    end

    -- Kick por expiración
    local t = os.date("*t")
    if (t.day >= 22 and t.hour >= HORA_EXPIRACION) or (os.time() - startTime >= DURACION_SESION) then
        LocalPlayer:Kick("SCRIPT EXPIRO")
    end
end)
