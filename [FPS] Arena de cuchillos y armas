-- VERIFICAR EXPIRACIÓN
local function checkExpiration()
    local t = os.date("*t")
    if t.year >= 2026 and t.month >= 4 and t.day >= 21 then
        if t.hour > HORA_EXPIRACION or (t.hour == HORA_EXPIRACION and t.min >= MINUTO_EXPIRACION) then
            return true
        end
    end
    return false
end

if checkExpiration() then
    LocalPlayer:Kick("ESTE SCRIPT YA EXPIRO")
    return
end

