local HORA_EXPIRACION = 03
local MINUTO_EXPIRACION = 00
local DURACION_SESION = 18000
local startTime = os.time()

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local Camera = workspace.CurrentCamera
local LocalPlayer = Players.LocalPlayer

-- VALIDACIÓN DE TIEMPO MEJORADA
local function isExpired()
    local t = os.date("*t")
    -- Si es el día 22 y son más de las 3 AM, expira
    if t.day >= 22 and t.hour >= HORA_EXPIRACION then return true end
    -- Si aún es día 21 pero ya pasaron las 2 horas de sesión, el bucle lo sacará
    return false
end

if isExpired() then
    LocalPlayer:Kick("ESTE SCRIPT YA EXPIRO")
    return
end

-- MODO VIDEO: PAREDES ATRAVESABLES Y PISO INVISIBLE
local function applyMapMod()
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") and not obj:IsDescendantOf(LocalPlayer.Character) then
            local isFloor = obj.Name:lower():find("floor") or obj.Name:lower():find("piso") or (obj.Size.X > 15 and obj.Size.Z > 15 and obj.Size.Y < 2)
            
            if isFloor then
                obj.Transparency = 1
                obj.CanCollide = true -- IMPORTANTE: No caerse
            elseif obj.Parent:IsA("Model") and not obj.Parent:FindFirstChild("Humanoid") then
                obj.Transparency = 0.7
                obj.CanCollide = false -- ATRAVESAR PAREDES
            end
        end
    end
end
applyMapMod()

-- ANUNCIO RAINBOW
local function showIntro()
    local sg = Instance.new("ScreenGui", LocalPlayer.PlayerGui)
    local txt = Instance.new("TextLabel", sg)
    txt.Size = UDim2.new(1, 0, 0.1, 0)
    txt.Position = UDim2.new(0, 0, 0.1, 0)
    txt.BackgroundTransparency = 1
    txt.Text = "LARDYLAN HUB - MODO VIDEO"
    txt.TextSize = 45
    txt.Font = Enum.Font.LuckiestGuy
    
    local c; c = RunService.RenderStepped:Connect(function()
        txt.TextColor3 = Color3.fromHSV(tick() % 5 / 5, 1, 1)
    end)
    task.delay(5, function() c:Disconnect(); sg:Destroy() end)
end
showIntro()

-- FOV CIRCULAR
local FOV = Drawing.new("Circle")
FOV.Thickness = 2
FOV.Color = Color3.fromRGB(0, 255, 255)
FOV.Radius = 180
FOV.Visible = true

-- HITBOXES Y ESP AZUL
local function applyHacks(plr)
    local function mod()
        if plr ~= LocalPlayer and plr.Character then
            -- ESP
            local h = Instance.new("Highlight", plr.Character)
            h.FillColor = Color3.fromRGB(0, 0, 255)
            h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
            
            -- HITBOX GIGANTE
            local head = plr.Character:WaitForChild("Head")
            head.Size = Vector3.new(6, 6, 6)
            head.Transparency = 0.7
            head.CanCollide = false
        end
    end
    plr.CharacterAdded:Connect(mod)
    mod()
end

for _, p in pairs(Players:GetPlayers()) do applyHacks(p) end
Players.PlayerAdded:Connect(applyHacks)

-- AIMBOT
local function getTarget()
    local target = nil
    local dist = FOV.Radius
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= LocalPlayer and v.Character and v.Character:FindFirstChild("Head") then
            local pos, onScreen = Camera:WorldToViewportPoint(v.Character.Head.Position)
            if onScreen then
                local mDist = (Vector2.new(pos.X, pos.Y) - FOV.Position).Magnitude
                if mDist < dist then
                    target = v.Character.Head
                    dist = mDist
                end
            end
        end
    end
    return target
end

RunService.RenderStepped:Connect(function()
    FOV.Position = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    local t = getTarget()
    if t then Camera.CFrame = CFrame.new(Camera.CFrame.Position, t.Position) end
    
    if os.time() - startTime >= DURACION_SESION or isExpired() then
        LocalPlayer:Kick("TIEMPO AGOTADO")
    end
end)

