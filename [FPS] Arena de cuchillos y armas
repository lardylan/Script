-- 3. ESP Y ANTENAS
local function applyESP(plr)
    local function createVisuals()
        if plr ~= LocalPlayer and plr.Character then
            local highlight = plr.Character:FindFirstChild("LardylanESP") or Instance.new("Highlight", plr.Character)
            highlight.Name = "LardylanESP"
            highlight.FillColor = Color3.fromRGB(0, 0, 255)
            highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
            
            local antenna = plr.Character:FindFirstChild("AntenaAzul") or Instance.new("Part", plr.Character)
            antenna.Name = "AntenaAzul"
            antenna.Size = Vector3.new(0.5, 30, 0.5)
            antenna.Color = Color3.fromRGB(0, 0, 255)
            antenna.Material = Enum.Material.Neon
            antenna.CanCollide = false
            
            local weld = antenna:FindFirstChild("Weld") or Instance.new("Weld", antenna)
            weld.Part0 = plr.Character:WaitForChild("Head")
            weld.Part1 = antenna
            weld.C0 = CFrame.new(0, 15, 0)
        end
    end
    plr.CharacterAdded:Connect(function() task.wait(1) createVisuals() end)
    createVisuals()
end
