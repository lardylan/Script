-- Función para los Switches (⚪)
local function createSwitch(name, posY, callback)
    local label = Instance.new("TextLabel", MenuPrincipal)
    label.Text = name
    label.Position = UDim2.new(0.1, 0, 0, posY)
    
    local btn = Instance.new("TextButton", MenuPrincipal)
    btn.Text = "⚪"
    btn.BackgroundColor3 = Color3.fromRGB(255, 0, 0) -- Rojo apagado
    btn.Position = UDim2.new(0.7, 0, 0, posY)
    btn.Size = UDim2.new(0, 50, 0, 30)
    
    local estado = false
    btn.MouseButton1Click:Connect(function()
        estado = not estado
        if estado then
            btn.BackgroundColor3 = Color3.fromRGB(0, 255, 0) -- Verde encendido
            btn.Text = "      ⚪" -- Se mueve a la derecha
        else
            btn.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
            btn.Text = "⚪      " -- Se mueve a la izquierda
        end
        callback(estado)
    end)
end

-- 3. FUNCIONES: HITGH (Hitbox) Y SPEED
createSwitch("HITGH", 100, function(v)
    _G.HitboxEnabled = v
    spawn(function()
        while _G.HitboxEnabled do
            for _, player in pairs(game.Players:GetPlayers()) do
                if player ~= game.Players.LocalPlayer and player.Character then
                    local hrp = player.Character:FindFirstChild("HumanoidRootPart")
                    if hrp then
                        hrp.Size = Vector3.new(15, 15, 15) -- El "cuadro gigante"
                        hrp.Transparency = 0.7
                        hrp.BrickColor = BrickColor.new("Black") -- Cuadro Negro
                        hrp.CanCollide = false
                    end
                end
            end
            task.wait(1)
        end
    end)
end)

createSwitch("SPEED", 160, function(v)
    if v then
        game.Players.LocalPlayer.Character.Humanoid.WalkSpeed = 100
    else
        game.Players.LocalPlayer.Character.Humanoid.WalkSpeed = 16
    end
end)

